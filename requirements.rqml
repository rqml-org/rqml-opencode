      <to><locator><local id="GOAL-PARITY"/></locator></to>
    </edge>
    <edge id="E-THIN-PARITY" type="satisfies" confidence="0.95">
      <from><locator><local id="REQ-THIN-ADAPTER"/></locator></from>
      <to><locator><local id="GOAL-PARITY"/></locator></to>
    </edge>
    <edge id="E-CONTRACT-PARITY" type="satisfies" confidence="0.8">
      <from><locator><local id="REQ-CLI-CONTRACT"/></locator></from>
      <to><locator><local id="GOAL-PARITY"/></locator></to>
    </edge>
    <edge id="E-STRICT-PARITY" type="satisfies" confidence="0.8">
      <from><locator><local id="REQ-STRICTNESS-RESPECT"/></locator></from>
      <to><locator><local id="GOAL-PARITY"/></locator></to>
    </edge>
    <edge id="E-HONEST-POSTURE" type="satisfies" confidence="0.95">
